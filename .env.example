# ============================================================
# Tunisian Lettre de Change OCR — Runtime Configuration
# Copy this file to .env in the project root and fill in values.
# ============================================================

# -------------------------------------------------------
# Inference mode
# Set to "api"   → use OpenRouter API (cloud, requires key)
# Set to "local" → use local GPU HTTP server (Ollama, vLLM, LMStudio)
# Set to "hf"    → load model directly from HuggingFace cache (no server needed)
#                  Requires: torch (CUDA), transformers, accelerate, bitsandbytes,
#                            qwen-vl-utils; ~5 GB VRAM with 4-bit quantization
# -------------------------------------------------------
INFERENCE_MODE=api

# -------------------------------------------------------
# OpenRouter API (used when INFERENCE_MODE=api)
# -------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use via OpenRouter.
# Qwen3 VL 8B Instruct is a good match for this task.
OPENROUTER_MODEL=qwen/qwen3-vl-8b-instruct

# OpenRouter endpoint (do not change unless advised)
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# -------------------------------------------------------
# Local inference server (used when INFERENCE_MODE=local)
# e.g. Ollama: http://localhost:11434/v1/chat/completions
#      vLLM:   http://localhost:8000/v1/chat/completions
#      LMStudio: http://localhost:1234/v1/chat/completions
# -------------------------------------------------------
LOCAL_ENDPOINT=http://localhost:11434/v1/chat/completions
LOCAL_MODEL=qwen3-vl-8b

# Timeout in seconds for each LLM request
LLM_TIMEOUT=60

# -------------------------------------------------------
# Direct HuggingFace inference (used when INFERENCE_MODE=hf)
# Model is loaded from your local HuggingFace cache — no HTTP server needed.
# Uses 4-bit NF4 quantization so it fits in 6-8 GB VRAM.
# -------------------------------------------------------
HF_MODEL=Qwen/Qwen3-VL-8B-Instruct
